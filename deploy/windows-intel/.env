LEDGER_IMAGE_TAG=3.9.0-linux-amd64

APP_IMAGE=ledger-app:${LEDGER_IMAGE_TAG}
MYSQL_IMAGE=ledger-mysql:${LEDGER_IMAGE_TAG}
NGINX_IMAGE=ledger-nginx:${LEDGER_IMAGE_TAG}
REDIS_IMAGE=redis:7.2-alpine

WEB_PORT=8081
APP_PORT=7070
MYSQL_PORT=3306
REDIS_PORT=6379

MYSQL_ROOT_PASSWORD=rootroot
REDIS_PASSWORD=12345678

LEDGER_HOST=host.docker.internal
JAVA_OPTS=-Xms512m -Xmx1024m
